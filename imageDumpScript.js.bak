// imageDumpScript.js - Deep Scan v1.1.0 med Progress Tracker
(function() {
  const newTab = window.open('about:blank', '_blank');
  if (!newTab) {
    alert("Popup blockerades! Tillåt popups.");
    return;
  }

  // CSS för laddningsskärmen
  const loadingHtml = `
    <html>
      <body style="background:#111217; color:#AF87D7; display:flex; flex-direction:column; justify-content:center; align-items:center; height:100vh; margin:0; font-family:sans-serif;">
        <h1 id="status">Initiating Deep Scan...</h1>
        <div style="width:300px; height:10px; background:#1A1B23; border:1px solid #554A6F; border-radius:5px; overflow:hidden; margin-top:20px;">
          <div id="progress-bar" style="width:0%; height:100%; background:#AF87D7; transition:width 0.2s;"></div>
        </div>
        <p id="percent" style="color:gray; margin-top:10px; font-size:14px;">0%</p>
      </body>
    </html>
  `;
  newTab.document.write(loadingHtml);

  function scrollToBottom(callback) {
    let scrollCount = 0;
    const maxScrolls = 20; 
    const distance = 800; 
    const interval = 150;

    const intervalId = setInterval(() => {
      window.scrollBy(0, distance);
      scrollCount++;
      
      // Uppdatera framsteg i den nya tabben
      const percentage = Math.round((scrollCount / maxScrolls) * 100);
      const bar = newTab.document.getElementById('progress-bar');
      const statusText = newTab.document.getElementById('status');
      const percentText = newTab.document.getElementById('percent');
      
      if (bar) bar.style.width = percentage + '%';
      if (percentText) percentText.innerText = percentage + '%';
      if (statusText) statusText.innerText = "Scanning " + window.location.hostname + "...Hold on.";

      if (scrollCount >= maxScrolls) {
        clearInterval(intervalId);
        window.scrollTo(0, 0);
        setTimeout(callback, 500); 
      }
    }, interval);
  }

  function collectAndDisplayImages() {
    const images = document.querySelectorAll('img');
    const rawUrls = Array.from(images)
      .map(img => img.currentSrc || img.src)
      .filter(src => src && src.startsWith('http') && !src.includes('pixel'));

    const uniqueImageUrls = [...new Set(rawUrls)];
    const domain = window.location.hostname;
    
    const htmlContent = `
      <!DOCTYPE html>
      <html>
        <head>
          <title>Image Collage - ${domain}</title>
          <style>
            body { background-color: #111217; color: white; font-family: sans-serif; margin: 0; padding: 20px; }
            .header { text-align: center; padding: 20px; border-bottom: 1px solid #554A6F; margin-bottom: 30px; }
            .header h1 { color: #AF87D7; margin: 0; }
            .collage { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; }
            
            .img-card { 
              background-color: #1A1B23; border: 1px solid #554A6F; height: 200px; 
              display: flex; align-items: center; justify-content: center; 
              overflow: hidden; cursor: zoom-in; transition: 0.2s;
            }
            .img-card:hover { border-color: #AF87D7; transform: scale(1.03); }
            .img-card img { max-width: 100%; max-height: 100%; object-fit: cover; pointer-events: none; }

            #overlay {
              display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
              background: rgba(0, 0, 0, 0.95); z-index: 10000;
              justify-content: center; align-items: center; cursor: zoom-out;
            }
            #overlay img { max-width: 95%; max-height: 95%; border: 1px solid #554A6F; box-shadow: 0 0 50px #000; }
            
            .footer { margin-top: 50px; text-align: center; color: gray; font-size: 11px; border-top: 1px solid #554A6F; padding: 20px; }
          </style>
        </head>
        <body>
          <div id="overlay" onclick="this.style.display='none'; document.body.style.overflow='auto';">
            <img id="overlay-img" src="">
          </div>

          <div class="header">
            <h1>${domain}</h1>
            <p>${uniqueImageUrls.length} unique images - Click to focus</p>
          </div>

          <div class="collage">
            ${uniqueImageUrls.map(url => `
              <div class="img-card" onclick="document.getElementById('overlay-img').src='${url}'; document.getElementById('overlay').style.display='flex'; document.body.style.overflow='hidden';">
                <img src="${url}">
              </div>
            `).join('')}
          </div>

          <div class="footer"><p>&copy; 2026 - wuseman</p></div>

          <script>
            document.addEventListener('keydown', e => {
              if (e.key === 'Escape') {
                document.getElementById('overlay').style.display = 'none';
                document.body.style.overflow = 'auto';
              }
            });
          </script>
        </body>
      </html>
    `;

    newTab.document.open();
    newTab.document.write(htmlContent);
    newTab.document.close();
  }

  scrollToBottom(collectAndDisplayImages);
})();
